# Lokale Laufzeitdaten
/data/db.sqlite
/data/*.sqlite
/data/*.sqlite-*
/data/*.db
/data/backups/*
!/data/backups/.gitkeep
/data/tmp/*
!/data/tmp/.gitkeep
/data/uploads/*
!/data/uploads/.gitkeep
/data/secrets/*
!/data/secrets/.gitkeep

# Environment (nie Secrets committen)
.env
!.env.example

# Python-Artefakte
__pycache__/
*.pyc
